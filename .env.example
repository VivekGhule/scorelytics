# Backend API Configuration
# Java Backend (Spring Boot) running on port 8080
VITE_API_BASE_URL=http://localhost:8080/api

# MongoDB Configuration (for Node Express server if used)
MONGODB_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/scorelytics

# JWT Secret (for Node Express server if used)
JWT_SECRET=your_jwt_secret_key_here

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here
